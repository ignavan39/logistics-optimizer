{
  "name": "logistics-optimizer",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "build": "nx run-many --target=build --all",
    "start:dev": "nx run-many --target=start:dev --all --parallel",
    "lint": "nx run-many --target=lint --all",
    "test": "nx run-many --target=test --all --pass-with-no-tests",
    "test:e2e": "jest --config tests/e2e/jest.config.js",
    "typecheck": "nx run-many --target=typecheck --all",
    "proto:gen": "bash infra/scripts/gen-proto.sh",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down -v",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@types/uuid": "^9.0.8",
    "@nx/eslint": "^22.6.5",
    "@nx/js": "^22.6.5",
    "@nx/nest": "^22.6.5",
    "@nx/node": "^22.6.5",
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "nx": "^22.6.5",
    "prettier": "^3.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
