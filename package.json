{
  "name": "logistics-optimizer",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "build": "nx run-many --target=build --all",
    "start:dev": "nx run-many --target=start:dev --all --parallel",
    "lint": "nx run-many --target=lint --all",
    "test": "nx run-many --target=test --all --pass-with-no-tests",
    "test:e2e": "jest --config tests/e2e/jest.config.js",
    "typecheck": "nx run-many --target=typecheck --all",
    "proto:gen": "bash infra/scripts/gen-proto.sh",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down -v",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/eslint": "^22.6.5",
    "@nx/jest": "22.6.5",
    "@nx/js": "^22.6.5",
    "@nx/nest": "^22.6.5",
    "@nx/node": "^22.6.5",
    "@nx/web": "22.6.5",
    "@nx/webpack": "22.6.5",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "axios": "^1.15.1",
    "eslint": "^8.57.0",
    "husky": "^9.0.0",
    "jest": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "lint-staged": "^15.0.0",
    "nx": "^22.6.5",
    "prettier": "~3.6.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.3.0",
    "typescript": "^5.4.5",
    "uuid": "^9.0.1",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@nestjs/common": "^10.3.8",
    "@nestjs/core": "^10.3.8",
    "@nestjs/platform-express": "^10.3.8",
    "express": "^5.2.1",
    "grpc-reflection-js": "^0.3.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "typeorm-naming-strategies": "^4.1.0"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
